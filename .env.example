# AstroSocial environment configuration (copy to .env and adjust).
# All variables are optional; sensible defaults are used when unset.

# This file is loaded automatically on startup (real environment variables that
# are already set take precedence over values here).

# --- Runtime ---------------------------------------------------------------
# NODE_ENV=production          # enables Secure cookies
# PORT=3000                    # HTTP port to listen on (e.g. PORT=8020)

# --- Storage / database ----------------------------------------------------
# OPENMEOW_DB_PATH=./data/openmeow.db
# OPENMEOW_UPLOADS_DIR=./uploads
# OPENMEOW_MIGRATIONS_DIR=./migrations

# --- Login PIN tuning ------------------------------------------------------
# OPENMEOW_PIN_TTL_MINUTES=10
# OPENMEOW_PIN_MAX_PER_WINDOW=5
# OPENMEOW_PIN_WINDOW_MINUTES=15
# OPENMEOW_PIN_MAX_FAILED_ATTEMPTS=5
# OPENMEOW_SESSION_TTL_DAYS=30

# --- Upload limits ---------------------------------------------------------
# OPENMEOW_MAX_IMAGE_BYTES=10485760
# OPENMEOW_MAX_VIDEO_BYTES=52428800

# --- Admin console ---------------------------------------------------------
# The admin console (/admin) authenticates against these constants. CHANGE THEM
# before exposing the server — the defaults (admin/admin) are for local dev only
# and the server logs a warning when they are in use.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin
# ADMIN_SESSION_TTL_HOURS=12

# --- Email (login PIN delivery) --------------------------------------------
# SMTP is configured at runtime via the admin Settings screen (stored in the
# database), not via environment variables. When no SMTP host is configured,
# login PINs are logged to the server console instead of emailed.
